#--- Application ---
# APP_NAME: Browser title, emails, PDF headers
# APP_ENV: local|staging|production — controls error display & logging
# APP_KEY: Generated via `php artisan key:generate` — encrypts sessions & cookies
# APP_URL/ASSET_URL: Base URLs for route() and asset() helpers
# APP_TIMEZONE: All dates stored & displayed in IST

APP_NAME="SHF World"
# APP_ENV=production
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=localhost
ASSET_URL=localhost
APP_TIMEZONE=Asia/Kolkata
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

#--- Maintenance & Server ---
# APP_MAINTENANCE_DRIVER: file (default) or database for multi-server setups
# PHP_CLI_SERVER_WORKERS: Parallel workers for `php artisan serve`
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database
# PHP_CLI_SERVER_WORKERS=4

#--- Security ---
# BCRYPT_ROUNDS: Higher = more secure but slower login (12 recommended)
BCRYPT_ROUNDS=12

#--- Logging ---
# LOG_CHANNEL=stack combines multiple channels (see config/logging.php)
# LOG_STACK=daily rotates log files by date, single writes to one file
# LOG_LEVEL: debug|info|notice|warning|error|critical|alert|emergency

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

#--- Database: Local Development ---
# DB_CONNECTION: mysql|sqlite|pgsql|sqlsrv
# These credentials are used when APP_ENV=local

DB_CONNECTION='mysql'
DB_HOST='127.0.0.1'
DB_PORT='3306'
DB_DATABASE='laravel'
DB_USERNAME='root'
DB_PASSWORD=

#--- Database: Production ---
# Separate credentials for live database, activated when APP_ENV=production
# See config/database.php for the switching logic

LIVE_DB_HOST='localhost'
LIVE_DB_PORT='3306'
LIVE_DB_DATABASE='laravel'
LIVE_DB_USERNAME=''root''
LIVE_DB_PASSWORD=

#--- Session ---
# SESSION_DRIVER: database|file|cookie|redis — database recommended for multi-server
# SESSION_LIFETIME: Inactivity timeout in minutes before user is logged out

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=

#--- Broadcasting, Filesystem & Queue ---
# BROADCAST_CONNECTION: log (dev) | pusher | redis for real-time events
# QUEUE_CONNECTION: database|redis|sync (sync = immediate, no background jobs)

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

#--- Cache ---
# CACHE_STORE: database|file|redis|memcached
# CACHE_PREFIX: Avoids key collisions if multiple apps share the same cache

CACHE_STORE=database
# CACHE_PREFIX=

#--- Redis & Memcached ---
# Only needed if using redis/memcached for cache, queue, or session

MEMCACHED_HOST=127.0.0.1
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

#--- Mail ---
# MAIL_MAILER: log (dev, writes to laravel.log) | smtp | mailgun | ses | postmark
# MAIL_FROM_*: Default sender on all outgoing emails

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

#--- AWS S3 ---
# Only needed if FILESYSTEM_DISK=s3 for file uploads

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

#--- Vite ---
VITE_APP_NAME="${APP_NAME}"

#--- PDF Generation ---
# CHROME_PATH: Path to Chrome/Chromium for headless PDF — auto-detected if not set
# PDF_SERVICE_URL/KEY: Fallback microservice when Chrome unavailable (shared hosting)
# PDF_USE_MICROSERVICE: Force microservice mode, skip local Chrome entirely
# CHROME_PATH="C:\Program Files\Google\Chrome\Application\chrome.exe"
# PDF_SERVICE_URL=http://127.0.0.1:3000/pdf
# PDF_SERVICE_KEY=
# PDF_USE_MICROSERVICE=false

#--- Impersonation (laravel-impersonate) ---
# 0 = only super_admin can impersonate (production)
# 1 = all users can impersonate (dev/testing)

ALLOW_IMPERSONATE_ALL=1
SHF_VERSION=20260417185506
SHOW_STAGE_IMPERSONATE=1
OPEN_RATE_PF_PARALLEL=1


REVERB_APP_ID=726906
REVERB_APP_KEY=axbmxbft9jgxbhrp0sgx
REVERB_APP_SECRET=g89mfhd1yubb1nup9a2q

# Client-facing (Echo / browser): connect via wss://localhost on 443.
# Herd Pro's Reverb service terminates TLS and proxies to the internal server.
REVERB_HOST="localhost"
REVERB_PORT=443
REVERB_SCHEME=https

# Server-facing (reverb:start binds here, Herd proxies to it).
REVERB_SERVER_HOST=127.0.0.1
REVERB_SERVER_PORT=8080

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Web Push (VAPID) — browser-native OS notifications even when the PWA is closed.
# Keep the private key out of VCS. Subject can be mailto: or a URL.
VAPID_SUBJECT="mailto:info@localhost.com"
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
